{% extends '@ibexadesign/ui/layout.html.twig' %}

{% block body_class %}clean-blog-contact-submissions{% endblock %}

{% block breadcrumbs %}
    {% include '@ibexadesign/ui/breadcrumbs.html.twig' with { items: [
        { value: 'Admin' },
        { value: 'Contact Submissions' }
    ]} %}
{% endblock %}

{% block header %}
    {% include '@ibexadesign/ui/page_title.html.twig' with {
        title: 'Contact Submissions',
    } %}
{% endblock %}

{% block content %}
    {% for flash_message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
            {{ flash_message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}

    <section class="mt-4">
        <div class="card ibexa-card ibexa-card--light mb-4">
            <div class="card-header ibexa-card__header d-flex justify-content-between align-items-center">
                <h5 class="ibexa-card__title mb-0">
                    All Submissions
                    {% if unread_count > 0 %}
                        <span class="badge bg-danger ms-2">{{ unread_count }} unread</span>
                    {% endif %}
                </h5>
                <span class="text-muted">{{ submissions|length }} total</span>
            </div>
            <div class="card-body ibexa-card__body p-0">
                {% if submissions|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 5%">#</th>
                                <th style="width: 5%"></th>
                                <th style="width: 18%">Name</th>
                                <th style="width: 22%">Email</th>
                                <th style="width: 25%">Subject</th>
                                <th style="width: 15%">Date</th>
                                <th style="width: 10%">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for submission in submissions %}
                            <tr class="{{ not submission.read ? 'fw-bold table-warning' : '' }}">
                                <td>{{ submission.id }}</td>
                                <td>
                                    {% if not submission.read %}
                                        <span class="badge bg-primary" title="Unread">●</span>
                                    {% endif %}
                                </td>
                                <td>{{ submission.name }}</td>
                                <td><a href="mailto:{{ submission.email }}">{{ submission.email }}</a></td>
                                <td>{{ submission.subject|length > 40 ? submission.subject[:40] ~ '...' : submission.subject }}</td>
                                <td>{{ submission.createdAt|date('M j, Y g:i A') }}</td>
                                <td>
                                    <a href="{{ path('clean_blog.admin.contact_submission_view', {id: submission.id}) }}" class="btn btn-sm btn-outline-primary" title="View">
                                        <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/><path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/></svg>
                                    </a>
                                    <a href="{{ path('clean_blog.admin.contact_submission_delete', {id: submission.id}) }}" class="btn btn-sm btn-outline-danger" title="Delete" onclick="return confirm('Are you sure you want to delete this submission?')">
                                        <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6z"/><path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118zM2.5 3V2h11v1h-11z"/></svg>
                                    </a>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% else %}
                <div class="text-center py-5 text-muted">
                    <svg width="48" height="48" fill="currentColor" viewBox="0 0 16 16" class="mb-3"><path d="M.05 3.555A2 2 0 0 1 2 2h12a2 2 0 0 1 1.95 1.555L8 8.414.05 3.555ZM0 4.697v7.104l5.803-3.558L0 4.697ZM6.761 8.83l-6.57 4.027A2 2 0 0 0 2 14h12a2 2 0 0 0 1.808-1.144l-6.57-4.027L8 9.586l-1.239-.757ZM16 11.801V4.697l-5.803 3.546L16 11.801Z"/></svg>
                    <p>No contact submissions yet.</p>
                </div>
                {% endif %}
            </div>
        </div>
    </section>
{% endblock %}
