<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
        <meta name="description" content="{% block meta_description %}{% endblock %}" />
        <meta name="author" content="" />
        <title>{% block title %}Clean Blog{% endblock %}</title>
        <link rel="icon" type="image/x-icon" href="{{ asset('bundles/aanwikibexacleanblogtheme/images/favicon.ico') }}" />
        <!-- Font Awesome icons (free version)-->
        <script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>
        <!-- Google fonts-->
        <link href="https://fonts.googleapis.com/css?family=Lora:400,700,400italic,700italic" rel="stylesheet" type="text/css" />
        <link href="https://fonts.googleapis.com/css?family=Open+Sans:300italic,400italic,600italic,700italic,800italic,400,300,600,700,800" rel="stylesheet" type="text/css" />
        <!-- Core theme CSS (includes Bootstrap)-->
        <link href="{{ asset('bundles/aanwikibexacleanblogtheme/css/styles.css') }}" rel="stylesheet" />
        {% block extra_css %}{% endblock %}
    </head>
    <body>
        {% include '@ibexadesign/header.html.twig' %}

        {% block masthead %}{% endblock %}

        {% block content %}{% endblock %}

        {% include '@ibexadesign/footer.html.twig' %}

        <!-- Bootstrap core JS-->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
        <!-- Core theme JS-->
        <script src="{{ asset('bundles/aanwikibexacleanblogtheme/js/scripts.js') }}"></script>
        {{ cookie_banner_render() }}
        {% block extra_js %}{% endblock %}
    </body>
</html>
